{
  "id": "secure-exec-onboarding",
  "title": "Secure Exec Architecture Tour",
  "description": "A guided walkthrough of the secure-exec monorepo — lightweight, infrastructure-free code execution using V8 isolates. Covers the core runtime, bridge layer, execution drivers, permissions model, testing strategy, and documentation.",
  "version": "1.0.0",
  "steps": [
    {
      "id": "overview",
      "title": "Welcome to Secure Exec",
      "description": "Secure Exec is a lightweight library for sandboxed Node.js and Python code execution without containers, VMs, or Docker. It uses V8 isolates — the same isolation behind Cloudflare Workers and browser tabs — to sandbox code at the process level. The monorepo is orchestrated with Turbo and pnpm, with packages split by concern: core types and bridge, platform-specific drivers, a website, and experimental runtimes.",
      "focusDirectory": "",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "monorepo-config",
          "name": "Monorepo Configuration",
          "color": "#38BDF8",
          "items": [
            { "path": "turbo.json", "type": "file" },
            { "path": "pnpm-workspace.yaml", "type": "file" },
            { "path": "package.json", "type": "file" },
            { "path": "CLAUDE.md", "type": "file" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "main-areas",
          "name": "Key Directories",
          "color": "#CC0000",
          "items": [
            { "path": "packages", "type": "directory" },
            { "path": "docs", "type": "directory" },
            { "path": "examples", "type": "directory" },
            { "path": "wasmvm", "type": "directory" }
          ],
          "opacity": 0.5,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "core-package",
      "title": "Core Types & Bridge",
      "description": "The core package defines Runtime API facades, the RuntimeDriver abstraction, and all shared types. It also contains the bridge — code injected into isolates at startup that implements Node.js API facades (fs, net, child_process, os, process).",
