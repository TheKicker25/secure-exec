{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build:bridge": {
      "outputs": ["assets/bridge.js"]
    },
    "build:wasix": {
      "outputs": ["assets/runtime.webc"],
      "cache": false
    },
    "build:npm": {
      "outputs": ["assets/npm/**"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "build:bridge", "build:wasix", "build:npm"],
      "outputs": ["dist/**"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
